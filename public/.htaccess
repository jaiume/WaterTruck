RewriteEngine On

# Don't rewrite existing files or directories
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# API routes - pass to api/index.php
RewriteRule ^api/(.*)$ api/index.php [QSA,L]

# SEO files - route to API for dynamic generation
RewriteRule ^sitemap\.xml$ api/index.php [QSA,L]
RewriteRule ^robots\.txt$ api/index.php [QSA,L]

# Clean URLs for pages
RewriteRule ^truck/?$ truck.php [L]
RewriteRule ^operator/?$ operator.php [L]
RewriteRule ^dispatcher/?$ dispatcher.php [L]
RewriteRule ^results/?$ results.php [L]
RewriteRule ^job/([a-zA-Z0-9-]+)/?$ job.php [L]
RewriteRule ^invite/([a-zA-Z0-9-]+)/?$ invite.php [L]

# Root URL serves index.php
RewriteRule ^$ index.php [L]
